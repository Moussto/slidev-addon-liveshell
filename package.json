    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/xterm": "5.5.0"
  },
  "devDependencies": {
    "@slidev/client": "0.50.0",
    "@slidev/types": "0.50.0",
    "typescript": "5.7.3",
    "vitest": "3.0.4",
    "vue": "3.5.13"
  }
